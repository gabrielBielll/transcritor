# Copie este arquivo para .env (local) ou configure como variáveis de ambiente
# no painel do Northflank. NÃO faça commit do .env com chaves reais.

# Obrigatória — crie em https://console.groq.com (grátis)
GROQ_API_KEY=coloque_sua_chave_groq_aqui

# Opcional — só necessária se você for usar o envio por e-mail (Resend)
RESEND_API_KEY=coloque_sua_chave_resend_aqui

# Porta (local). No Northflank isso é definido automaticamente.
PORT=8080
